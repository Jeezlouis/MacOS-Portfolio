{
    "compilerOptions": {
        "target": "ES2022",
        "lib": [
            "ES2022",
            "DOM",
            "DOM.Iterable"
        ],
        "module": "ESNext",
        "moduleResolution": "bundler",
        "jsx": "react-jsx",
        "forceConsistentCasingInFileNames": false,
        "baseUrl": ".",
        "paths": {
            "#*": [
                "src/*"
            ]
        }
    },
    "include": [
        "src"
    ]
}